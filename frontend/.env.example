# ============================================================
# NexKan frontend environment (development only)
# Copy to frontend/.env and set VITE_API_URL:
#   cp frontend/.env.example frontend/.env
#
# In production the frontend is served by nginx as static files
# and proxies /api to the backend — no .env needed.
# ============================================================

# Backend API base URL used by the Vite dev server.
# Point this at the backend when running `npm run dev` locally.
VITE_API_URL=http://localhost:3000/api
