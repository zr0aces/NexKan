# ============================================================
# NexKan environment configuration
# Copy to .env and fill in the required values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Docker / nginx
# ------------------------------------------------------------

# Host port that nginx binds to. Access the app at http://localhost:HOST_PORT
HOST_PORT=8092

# ------------------------------------------------------------
# Backend server
# ------------------------------------------------------------

PORT=3000
NODE_ENV=production
TZ=UTC                        # e.g. Europe/Berlin, Asia/Bangkok, America/New_York

# In-container paths — only change these if you alter the volume mounts in docker-compose.yml
DATA_DIR=/app/data/tasks
NOTIFICATIONS_FILE=/app/data/notifications-sent.json

# ------------------------------------------------------------
# Telegram bot  (leave blank to disable Telegram features)
# ------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your personal Telegram user/group ID (send a message to @userinfobot to find it)
TELEGRAM_CHAT_ID=

# Public HTTPS URL where Telegram delivers webhook updates
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/webhooks/telegram

# Secret token Telegram includes in every webhook request (generate with: openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=

# Secret for the POST /api/notifications/check cron endpoint (generate with: openssl rand -hex 32)
CRON_SECRET=
